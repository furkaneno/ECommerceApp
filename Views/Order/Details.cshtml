@model Order
@{
    ViewData["Title"] = $"Order #{Model.Id:D6}";
    var statusClass = Model.Status switch {
        OrderStatus.Pending => "badge-status-pending",
        OrderStatus.Processing => "badge-status-processing",
        OrderStatus.Shipped => "badge-status-shipped",
        OrderStatus.Delivered => "badge-status-delivered",
        OrderStatus.Cancelled => "badge-status-cancelled",
        _ => "badge-status-pending"
    };
}

<div class="page-header">
    <div class="container">
        <h1>Order #@Model.Id.ToString("D6")</h1>
        <p style="color:rgba(255,255,255,0.55); margin:0; font-size:0.92rem">Placed on @Model.OrderDate.ToString("MMMM dd, yyyy")</p>
    </div>
</div>

<div class="container pb-5">
    <div class="mb-3">
        <a href="/Order/History" class="text-decoration-none" style="color:var(--brand-gold); font-size:0.88rem;">
            <i class="bi bi-arrow-left me-1"></i>Back to My Orders
        </a>
    </div>

    <div class="row g-4 align-items-start">
        <div class="col-lg-8">
            <div class="form-card">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="brand-font mb-0">Items Ordered</h5>
                    <span class="badge @statusClass px-3 py-2" style="font-size:0.85rem; border-radius:20px;">@Model.Status</span>
                </div>

                @foreach (var item in Model.OrderItems)
                {
                    <div class="d-flex gap-3 align-items-center mb-4 pb-4" style="border-bottom:1px solid var(--brand-border);">
                        <div style="width:70px; height:70px; border-radius:10px; overflow:hidden; border:1px solid var(--brand-border); flex-shrink:0; background:var(--brand-light);">
                            @if (!string.IsNullOrEmpty(item.Product?.ImageUrl))
                            {
                                <img src="@item.Product.ImageUrl" alt="" style="width:100%; height:100%; object-fit:cover;" />
                            }
                        </div>
                        <div class="flex-grow-1">
                            <a href="/Product/Details/@item.ProductId" class="text-decoration-none"
                               style="font-family:'Playfair Display',serif; font-weight:500; font-size:0.98rem; color:var(--brand-dark);">
                                @item.Product?.Name
                            </a>
                            <div class="d-flex gap-3 mt-1">
                                <span style="font-size:0.82rem; color:var(--brand-muted);">Unit: $@item.UnitPrice.ToString("N2")</span>
                                <span style="font-size:0.82rem; color:var(--brand-muted);">Qty: @item.Quantity</span>
                            </div>
                        </div>
                        <div style="font-weight:700; font-size:1.05rem; white-space:nowrap;">
                            $@((item.Quantity * item.UnitPrice).ToString("N2"))
                        </div>
                    </div>
                }

                <div class="pt-2">
                    <div class="d-flex justify-content-between mb-2" style="font-size:0.9rem;">
                        <span class="text-muted">Subtotal (@Model.OrderItems.Sum(i => i.Quantity) items)</span>
                        <span class="fw-semibold">$@Model.TotalAmount.ToString("N2")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3" style="font-size:0.9rem;">
                        <span class="text-muted">Shipping</span>
                        <span class="fw-semibold text-success">@(Model.TotalAmount >= 50 ? "FREE" : "$9.99")</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span style="font-weight:700; font-size:1rem;">Total</span>
                        <span style="font-weight:700; font-size:1.3rem;">
                            $@((Model.TotalAmount + (Model.TotalAmount >= 50 ? 0 : 9.99m)).ToString("N2"))
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="form-card">
                <h6 style="font-weight:700; text-transform:uppercase; letter-spacing:0.08em; font-size:0.78rem; color:var(--brand-muted); margin-bottom:1rem;">Order Info</h6>

                <div class="mb-3">
                    <div style="font-size:0.78rem; color:var(--brand-muted); margin-bottom:2px;">Order Number</div>
                    <div style="font-weight:700;">#@Model.Id.ToString("D6")</div>
                </div>
                <div class="mb-3">
                    <div style="font-size:0.78rem; color:var(--brand-muted); margin-bottom:2px;">Date Placed</div>
                    <div style="font-weight:600;">@Model.OrderDate.ToString("MMM dd, yyyy h:mm tt")</div>
                </div>
                <div class="mb-3">
                    <div style="font-size:0.78rem; color:var(--brand-muted); margin-bottom:2px;">Status</div>
                    <span class="badge @statusClass px-3 py-2" style="font-size:0.82rem; border-radius:20px;">@Model.Status</span>
                </div>

                @if (!string.IsNullOrEmpty(Model.ShippingAddress))
                {
                    <hr style="border-color:var(--brand-border);" />
                    <div class="mb-3">
                        <div style="font-size:0.78rem; color:var(--brand-muted); margin-bottom:4px;">Shipping Address</div>
                        <div style="font-size:0.88rem; line-height:1.6; white-space:pre-line;">@Model.ShippingAddress</div>
                    </div>
                }

                @if (!string.IsNullOrEmpty(Model.Notes))
                {
                    <div>
                        <div style="font-size:0.78rem; color:var(--brand-muted); margin-bottom:4px;">Order Notes</div>
                        <div style="font-size:0.88rem; line-height:1.6;">@Model.Notes</div>
                    </div>
                }
            </div>

            <div class="mt-3">
                <a href="/Product" class="btn btn-gold w-100">
                    <i class="bi bi-bag me-2"></i>Continue Shopping
                </a>
            </div>
        </div>
    </div>
</div>
