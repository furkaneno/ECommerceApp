@model IEnumerable<Order>
@{
    ViewData["Title"] = "My Orders";
}

<div class="page-header">
    <div class="container">
        <h1><i class="bi bi-clock-history me-3"></i>My Orders</h1>
        <p style="color:rgba(255,255,255,0.55); margin:0; font-size:0.92rem">@Model.Count() order(s) placed</p>
    </div>
</div>

<div class="container pb-5">
    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <div style="width:90px; height:90px; background:var(--brand-light); border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 1.5rem;">
                <i class="bi bi-bag" style="font-size:2.5rem; color:var(--brand-muted);"></i>
            </div>
            <h3 class="brand-font">No orders yet</h3>
            <p class="text-muted">You haven't placed any orders. Start shopping!</p>
            <a href="/Product" class="btn btn-gold btn-lg px-5 mt-2">
                <i class="bi bi-grid me-2"></i>Browse Products
            </a>
        </div>
    }
    else
    {
        <div class="d-flex flex-column gap-4">
            @foreach (var order in Model)
            {
                var statusClass = order.Status switch {
                    OrderStatus.Pending => "badge-status-pending",
                    OrderStatus.Processing => "badge-status-processing",
                    OrderStatus.Shipped => "badge-status-shipped",
                    OrderStatus.Delivered => "badge-status-delivered",
                    OrderStatus.Cancelled => "badge-status-cancelled",
                    _ => "badge-status-pending"
                };

                <div class="form-card p-0 overflow-hidden">
                    <!-- Order Header -->
                    <div class="p-3 d-flex flex-wrap justify-content-between align-items-center gap-3"
                         style="background:var(--brand-light); border-bottom:1px solid var(--brand-border);">
                        <div class="d-flex gap-4 flex-wrap">
                            <div>
                                <div style="font-size:0.72rem; text-transform:uppercase; letter-spacing:0.1em; color:var(--brand-muted); font-weight:700;">Order #</div>
                                <div style="font-weight:700; font-family:'Playfair Display',serif;">@order.Id.ToString("D6")</div>
                            </div>
                            <div>
                                <div style="font-size:0.72rem; text-transform:uppercase; letter-spacing:0.1em; color:var(--brand-muted); font-weight:700;">Date</div>
                                <div style="font-weight:600; font-size:0.9rem;">@order.OrderDate.ToString("MMM dd, yyyy")</div>
                            </div>
                            <div>
                                <div style="font-size:0.72rem; text-transform:uppercase; letter-spacing:0.1em; color:var(--brand-muted); font-weight:700;">Total</div>
                                <div style="font-weight:700; font-size:1rem;">$@order.TotalAmount.ToString("N2")</div>
                            </div>
                            <div>
                                <div style="font-size:0.72rem; text-transform:uppercase; letter-spacing:0.1em; color:var(--brand-muted); font-weight:700;">Items</div>
                                <div style="font-weight:600; font-size:0.9rem;">@order.OrderItems.Sum(i => i.Quantity)</div>
                            </div>
                        </div>
                        <span class="badge @statusClass px-3 py-2" style="font-size:0.82rem; border-radius:20px; font-weight:600;">
                            @order.Status
                        </span>
                    </div>

                    <!-- Order Items Preview -->
                    <div class="p-3">
                        <div class="d-flex gap-2 flex-wrap">
                            @foreach (var item in order.OrderItems.Take(4))
                            {
                                <div style="display:flex; align-items:center; gap:0.6rem; background:var(--brand-cream); border:1px solid var(--brand-border); border-radius:8px; padding:0.5rem 0.8rem;">
                                    @if (!string.IsNullOrEmpty(item.Product?.ImageUrl))
                                    {
                                        <img src="@item.Product.ImageUrl" alt=""
                                             style="width:32px; height:32px; object-fit:cover; border-radius:4px;" />
                                    }
                                    <span style="font-size:0.82rem; font-weight:500; max-width:140px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                                        @item.Product?.Name
                                    </span>
                                    <span style="font-size:0.75rem; color:var(--brand-muted);">×@item.Quantity</span>
                                </div>
                            }
                            @if (order.OrderItems.Count > 4)
                            {
                                <div style="background:var(--brand-light); border:1px solid var(--brand-border); border-radius:8px; padding:0.5rem 0.8rem; font-size:0.82rem; color:var(--brand-muted); display:flex; align-items:center;">
                                    +@(order.OrderItems.Count - 4) more
                                </div>
                            }
                        </div>
                    </div>

                    <div class="px-3 pb-3 d-flex justify-content-end">
                        <a href="/Order/Details/@order.Id" class="btn btn-sm btn-outline-brand">
                            View Details <i class="bi bi-arrow-right ms-1"></i>
                        </a>
                    </div>
                </div>
            }
        </div>
    }
</div>
