@model Order
@{
    ViewData["Title"] = "Order Confirmed";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-7">

            <!-- Success Banner -->
            <div class="text-center mb-5">
                <div style="width:90px; height:90px; background:linear-gradient(135deg, #d4edda, #c3e6cb); border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 1.5rem; border:3px solid #c8e6c9;">
                    <i class="bi bi-check-lg" style="font-size:2.5rem; color:#155724;"></i>
                </div>
                <h1 style="font-family:'Playfair Display',serif; font-size:2.2rem; font-weight:700; color:var(--brand-dark);">Order Confirmed!</h1>
                <p class="text-muted" style="font-size:1rem; max-width:400px; margin:0.5rem auto 0;">
                    Thank you for your purchase. Your order has been placed and is being processed.
                </p>
            </div>

            <!-- Order Details Card -->
            <div class="form-card mb-4">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
                    <div>
                        <div style="font-size:0.75rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:var(--brand-muted);">Order Number</div>
                        <div style="font-size:1.5rem; font-weight:700; font-family:'Playfair Display',serif;">#@Model.Id.ToString("D6")</div>
                    </div>
                    <div class="text-end">
                        <div style="font-size:0.75rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:var(--brand-muted);">Order Date</div>
                        <div style="font-weight:600;">@Model.OrderDate.ToString("MMMM dd, yyyy")</div>
                    </div>
                    <div>
                        <span class="badge badge-status-pending px-3 py-2" style="font-size:0.82rem; border-radius:20px;">
                            <i class="bi bi-clock me-1"></i>@Model.Status
                        </span>
                    </div>
                </div>

                <!-- Items -->
                <h6 style="font-weight:700; font-size:0.8rem; letter-spacing:0.1em; text-transform:uppercase; color:var(--brand-muted); margin-bottom:1rem;">Items Ordered</h6>

                @foreach (var item in Model.OrderItems)
                {
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <div style="width:55px; height:55px; border-radius:8px; overflow:hidden; border:1px solid var(--brand-border); flex-shrink:0; background:var(--brand-light);">
                            @if (!string.IsNullOrEmpty(item.Product?.ImageUrl))
                            {
                                <img src="@item.Product.ImageUrl" alt="@item.Product?.Name" style="width:100%; height:100%; object-fit:cover;" />
                            }
                        </div>
                        <div class="flex-grow-1">
                            <div style="font-weight:500;">@item.Product?.Name</div>
                            <div style="font-size:0.82rem; color:var(--brand-muted);">Qty: @item.Quantity × $@item.UnitPrice.ToString("N2")</div>
                        </div>
                        <div style="font-weight:700;">$@((item.Quantity * item.UnitPrice).ToString("N2"))</div>
                    </div>
                }

                <hr style="border-color:var(--brand-border);" />

                <!-- Totals -->
                <div class="d-flex justify-content-between mb-1" style="font-size:0.9rem;">
                    <span class="text-muted">Subtotal</span>
                    <span class="fw-semibold">$@Model.TotalAmount.ToString("N2")</span>
                </div>
                <div class="d-flex justify-content-between mb-3" style="font-size:0.9rem;">
                    <span class="text-muted">Shipping</span>
                    <span class="fw-semibold text-success">@(Model.TotalAmount >= 50 ? "FREE" : "$9.99")</span>
                </div>
                <div class="d-flex justify-content-between">
                    <span style="font-weight:700; font-size:1rem;">Total Charged</span>
                    <span style="font-weight:700; font-size:1.3rem;">$@((Model.TotalAmount + (Model.TotalAmount >= 50 ? 0 : 9.99m)).ToString("N2"))</span>
                </div>

                @if (!string.IsNullOrEmpty(Model.ShippingAddress))
                {
                    <hr style="border-color:var(--brand-border);" />
                    <div>
                        <div style="font-size:0.75rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; color:var(--brand-muted); margin-bottom:0.4rem;">Shipping To</div>
                        <div style="font-size:0.9rem; line-height:1.6; white-space:pre-line;">@Model.ShippingAddress</div>
                    </div>
                }
            </div>

            <!-- Actions -->
            <div class="d-flex gap-3 flex-wrap justify-content-center">
                <a href="/Order/History" class="btn btn-primary-brand btn-lg px-4">
                    <i class="bi bi-clock-history me-2"></i>My Orders
                </a>
                <a href="/Product" class="btn btn-gold btn-lg px-4">
                    <i class="bi bi-bag me-2"></i>Continue Shopping
                </a>
            </div>

        </div>
    </div>
</div>
