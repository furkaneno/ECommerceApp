@model RegisterViewModel
@{
    ViewData["Title"] = "Create Account";
    Layout = "_Layout";
}

<div style="min-height:80vh; display:flex; align-items:center; background:var(--brand-cream); padding:3rem 0;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5">

                <div class="text-center mb-4">
                    <a href="/" class="text-decoration-none">
                        <div style="font-family:'Playfair Display',serif; font-size:2.2rem; font-weight:700; color:var(--brand-dark);">Lumière</div>
                    </a>
                    <h2 class="mt-3" style="font-family:'Playfair Display',serif; font-size:1.6rem;">Create an account</h2>
                    <p class="text-muted" style="font-size:0.9rem;">Join us and start shopping today</p>
                </div>

                <div class="form-card">
                    <form asp-action="Register" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label asp-for="FullName" class="form-label">Full Name</label>
                            <input asp-for="FullName" type="text" class="form-control" placeholder="Jane Doe" autocomplete="name" />
                            <span asp-validation-for="FullName" class="text-danger" style="font-size:0.82rem;"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label">Email Address</label>
                            <input asp-for="Email" type="email" class="form-control" placeholder="you@example.com" autocomplete="email" />
                            <span asp-validation-for="Email" class="text-danger" style="font-size:0.82rem;"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label">Password</label>
                            <div class="position-relative">
                                <input asp-for="Password" type="password" class="form-control"
                                       placeholder="At least 6 characters" id="passwordField" autocomplete="new-password" />
                                <button type="button" class="btn position-absolute end-0 top-0 h-100 px-3"
                                        style="background:none; border:none; color:var(--brand-muted);"
                                        onclick="togglePwd('passwordField','eyeIcon1')">
                                    <i class="bi bi-eye" id="eyeIcon1"></i>
                                </button>
                            </div>
                            <span asp-validation-for="Password" class="text-danger" style="font-size:0.82rem;"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ConfirmPassword" class="form-label">Confirm Password</label>
                            <div class="position-relative">
                                <input asp-for="ConfirmPassword" type="password" class="form-control"
                                       placeholder="Repeat your password" id="confirmField" autocomplete="new-password" />
                                <button type="button" class="btn position-absolute end-0 top-0 h-100 px-3"
                                        style="background:none; border:none; color:var(--brand-muted);"
                                        onclick="togglePwd('confirmField','eyeIcon2')">
                                    <i class="bi bi-eye" id="eyeIcon2"></i>
                                </button>
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="text-danger" style="font-size:0.82rem;"></span>
                        </div>

                        <button type="submit" class="btn btn-gold w-100 btn-lg mb-3">
                            <i class="bi bi-person-plus me-2"></i>Create Account
                        </button>

                        <div class="text-center">
                            <span style="font-size:0.88rem; color:var(--brand-muted);">Already have an account?</span>
                            <a href="/Account/Login" class="ms-1 text-decoration-none fw-semibold" style="color:var(--brand-gold);">Sign in</a>
                        </div>
                    </form>
                </div>

                <p class="text-center mt-3" style="font-size:0.78rem; color:var(--brand-muted);">
                    By creating an account, you agree to our Terms of Service and Privacy Policy.
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
function togglePwd(fieldId, iconId) {
    const field = document.getElementById(fieldId);
    const icon = document.getElementById(iconId);
    if (field.type === 'password') {
        field.type = 'text';
        icon.className = 'bi bi-eye-slash';
    } else {
        field.type = 'password';
        icon.className = 'bi bi-eye';
    }
}
</script>
}
