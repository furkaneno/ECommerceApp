@model IEnumerable<Order>
@{
    ViewData["Title"] = "Manage Orders";
}

<div class="page-header">
    <div class="container d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
            <h1><i class="bi bi-bag-check me-3"></i>Orders</h1>
            <p style="color:rgba(255,255,255,0.55); margin:0; font-size:0.92rem">@Model.Count() total orders</p>
        </div>
        <a href="/Admin" class="btn btn-outline-light"><i class="bi bi-speedometer2 me-2"></i>Dashboard</a>
    </div>
</div>

<div class="container pb-5">

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-inbox" style="font-size:3rem; color:var(--brand-muted);"></i>
            <h4 class="mt-3 brand-font">No Orders Yet</h4>
            <p class="text-muted">Orders will appear here once customers start shopping.</p>
        </div>
    }
    else
    {
        <div class="form-card p-0 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-brand mb-0">
                    <thead>
                        <tr>
                            <th>Order #</th>
                            <th>Customer</th>
                            <th>Date</th>
                            <th>Items</th>
                            <th>Total</th>
                            <th>Status</th>
                            <th style="width:220px;">Update Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model)
                        {
                            var statusClass = order.Status switch {
                                OrderStatus.Pending => "badge-status-pending",
                                OrderStatus.Processing => "badge-status-processing",
                                OrderStatus.Shipped => "badge-status-shipped",
                                OrderStatus.Delivered => "badge-status-delivered",
                                OrderStatus.Cancelled => "badge-status-cancelled",
                                _ => "badge-status-pending"
                            };
                            <tr>
                                <td><strong>#@order.Id.ToString("D6")</strong></td>
                                <td>
                                    <div style="font-weight:500;">@order.User?.FullName</div>
                                    <div style="font-size:0.78rem; color:var(--brand-muted);">@order.User?.Email</div>
                                </td>
                                <td style="font-size:0.88rem; color:var(--brand-muted);">@order.OrderDate.ToString("MMM dd, yyyy")</td>
                                <td>@order.OrderItems.Sum(i => i.Quantity) items</td>
                                <td><strong>$@order.TotalAmount.ToString("N2")</strong></td>
                                <td>
                                    <span class="badge @statusClass px-2 py-1" style="font-size:0.78rem; border-radius:20px;">
                                        @order.Status
                                    </span>
                                </td>
                                <td>
                                    <form action="/Admin/UpdateOrderStatus" method="post" class="d-flex gap-2">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="orderId" value="@order.Id" />
                                        <select name="status" class="form-select form-select-sm" style="font-size:0.82rem;">
                                            @foreach (OrderStatus s in Enum.GetValues(typeof(OrderStatus)))
                                            {
                                                <option value="@s" selected="@(s == order.Status ? "selected" : null)">@s</option>
                                            }
                                        </select>
                                        <button type="submit" class="btn btn-sm btn-gold px-2" title="Update">
                                            <i class="bi bi-check2"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
