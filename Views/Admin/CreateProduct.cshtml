@model ProductViewModel
@{
    ViewData["Title"] = "Add Product";
    var categories = ViewBag.Categories as IEnumerable<ECommerceApp.Models.Category> ?? new List<ECommerceApp.Models.Category>();
}

<div class="page-header">
    <div class="container">
        <h1><i class="bi bi-plus-circle me-3"></i>Add New Product</h1>
        <p style="color:rgba(255,255,255,0.55); margin:0; font-size:0.92rem">Fill in the details below</p>
    </div>
</div>

<div class="container pb-5">
    <div class="mb-3">
        <a href="/Admin/Products" class="text-decoration-none" style="color:var(--brand-gold); font-size:0.88rem;">
            <i class="bi bi-arrow-left me-1"></i>Back to Products
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="form-card">
                <form asp-action="CreateProduct" method="post">
                    @Html.AntiForgeryToken()

                    <div class="row g-4">
                        <div class="col-12">
                            <label asp-for="Name" class="form-label">Product Name <span style="color:#dc3545">*</span></label>
                            <input asp-for="Name" class="form-control" placeholder="e.g. Premium Wireless Headphones" />
                            <span asp-validation-for="Name" class="text-danger" style="font-size:0.82rem;"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Description" class="form-label">Description</label>
                            <textarea asp-for="Description" class="form-control" rows="4"
                                      placeholder="Detailed product description..."></textarea>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Price" class="form-label">Price ($) <span style="color:#dc3545">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text" style="background:var(--brand-light); border:1.5px solid var(--brand-border); border-right:none;">$</span>
                                <input asp-for="Price" type="number" step="0.01" min="0.01" class="form-control" placeholder="0.00" style="border-left:none;" />
                            </div>
                            <span asp-validation-for="Price" class="text-danger" style="font-size:0.82rem;"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Stock" class="form-label">Stock Quantity <span style="color:#dc3545">*</span></label>
                            <input asp-for="Stock" type="number" min="0" class="form-control" placeholder="0" />
                            <span asp-validation-for="Stock" class="text-danger" style="font-size:0.82rem;"></span>
                        </div>

                        <div class="col-md-8">
                            <label asp-for="CategoryId" class="form-label">Category <span style="color:#dc3545">*</span></label>
                            <select asp-for="CategoryId" class="form-select">
                                <option value="">— Select a category —</option>
                                @foreach (var cat in categories)
                                {
                                    <option value="@cat.Id">@cat.Name</option>
                                }
                            </select>
                            <span asp-validation-for="CategoryId" class="text-danger" style="font-size:0.82rem;"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="IsActive" class="form-label">Visibility</label>
                            <div class="form-check form-switch mt-2">
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" id="isActiveSwitch" checked />
                                <label class="form-check-label" for="isActiveSwitch">Active (visible to shoppers)</label>
                            </div>
                        </div>

                        <div class="col-12">
                            <label asp-for="ImageUrl" class="form-label">Image URL <span class="text-muted">(optional)</span></label>
                            <input asp-for="ImageUrl" type="url" class="form-control"
                                   placeholder="https://example.com/image.jpg"
                                   oninput="previewImage(this.value)" />
                            <div class="form-text">Use an absolute URL from the web (e.g. Unsplash, your CDN)</div>
                        </div>

                        <!-- Image Preview -->
                        <div class="col-12" id="previewContainer" style="display:none;">
                            <label class="form-label">Preview</label>
                            <div style="width:180px; height:135px; border-radius:10px; overflow:hidden; border:1px solid var(--brand-border); background:var(--brand-light);">
                                <img id="imgPreview" src="" alt="" style="width:100%; height:100%; object-fit:cover;" />
                            </div>
                        </div>
                    </div>

                    <hr style="border-color:var(--brand-border); margin:2rem 0 1.5rem;" />

                    <div class="d-flex gap-3">
                        <button type="submit" class="btn btn-gold btn-lg px-5">
                            <i class="bi bi-check-circle me-2"></i>Create Product
                        </button>
                        <a href="/Admin/Products" class="btn btn-outline-brand btn-lg">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
function previewImage(url) {
    const container = document.getElementById('previewContainer');
    const img = document.getElementById('imgPreview');
    if (url && url.startsWith('http')) {
        img.src = url;
        container.style.display = 'block';
        img.onerror = () => { container.style.display = 'none'; };
    } else {
        container.style.display = 'none';
    }
}
</script>
}
