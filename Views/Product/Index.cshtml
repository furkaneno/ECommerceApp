@model ProductListViewModel
@{
    ViewData["Title"] = "Shop";
}

<div class="page-header">
    <div class="container">
        <h1>@(Model.CategoryName ?? "All Products")</h1>
        <p style="color:rgba(255,255,255,0.55); margin:0; font-size:0.92rem">
            @Model.Products.Count() product(s)
            @if (!string.IsNullOrEmpty(Model.SearchQuery)) { <text>for "@Model.SearchQuery"</text> }
        </p>
    </div>
</div>

<div class="container pb-5">
    <!-- Filters Row -->
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
        <!-- Category Pills -->
        <div class="d-flex flex-wrap gap-2">
            <a href="/Product" class="btn btn-sm @(Model.SelectedCategoryId == null ? "btn-primary-brand" : "btn-outline-brand")">All</a>
            @foreach (var cat in Model.Categories)
            {
                <a href="/Product?categoryId=@cat.Id@(!string.IsNullOrEmpty(Model.SearchQuery) ? "&search=" + Model.SearchQuery : "")"
                   class="btn btn-sm @(Model.SelectedCategoryId == cat.Id ? "btn-primary-brand" : "btn-outline-brand")">
                    @cat.Name
                </a>
            }
        </div>
        <!-- Search -->
        <form class="d-flex gap-2" method="get" action="/Product">
            @if (Model.SelectedCategoryId.HasValue)
            {
                <input type="hidden" name="categoryId" value="@Model.SelectedCategoryId" />
            }
            <input type="text" name="search" class="form-control form-control-sm"
                   placeholder="Search products..." value="@Model.SearchQuery" style="width:200px" />
            <button type="submit" class="btn btn-sm btn-gold"><i class="bi bi-search"></i></button>
            @if (!string.IsNullOrEmpty(Model.SearchQuery))
            {
                <a href="/Product@(Model.SelectedCategoryId.HasValue ? "?categoryId=" + Model.SelectedCategoryId : "")"
                   class="btn btn-sm btn-outline-brand">
                    <i class="bi bi-x"></i>
                </a>
            }
        </form>
    </div>

    @if (!Model.Products.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-box-seam" style="font-size:3.5rem; color:var(--brand-muted);"></i>
            <h4 class="mt-3 brand-font">No Products Found</h4>
            <p class="text-muted">Try adjusting your filters or search terms.</p>
            <a href="/Product" class="btn btn-gold mt-2">Clear Filters</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var product in Model.Products)
            {
                <div class="col-6 col-md-4 col-lg-3">
                    <div class="product-card h-100 d-flex flex-column">
                        <a href="/Product/Details/@product.Id" class="text-decoration-none">
                            <div class="product-card-img-wrap">
                                @if (!string.IsNullOrEmpty(product.ImageUrl))
                                {
                                    <img src="@product.ImageUrl" alt="@product.Name" loading="lazy" />
                                }
                                else
                                {
                                    <div class="d-flex align-items-center justify-content-center h-100 bg-light">
                                        <i class="bi bi-image text-muted fs-2"></i>
                                    </div>
                                }
                            </div>
                        </a>
                        <div class="product-card-body d-flex flex-column flex-grow-1">
                            <div class="product-category-tag">@product.Category.Name</div>
                            <a href="/Product/Details/@product.Id" class="text-decoration-none">
                                <div class="product-title">@product.Name</div>
                            </a>
                            @if (!string.IsNullOrEmpty(product.Description))
                            {
                                <p class="text-muted mt-1 flex-grow-1" style="font-size:0.82rem; line-height:1.5;">
                                    @(product.Description.Length > 70 ? product.Description.Substring(0, 70) + "…" : product.Description)
                                </p>
                            }
                            <div class="mt-auto pt-2">
                                <div class="d-flex align-items-center justify-content-between mb-3">
                                    <span class="product-price">$@product.Price.ToString("N2")</span>
                                    <span class="text-muted" style="font-size:0.78rem;">
                                        @if (product.Stock > 0) { <text>@product.Stock in stock</text> }
                                        else { <span style="color:#dc3545">Out of stock</span> }
                                    </span>
                                </div>
                                @if (product.Stock > 0)
                                {
                                    <form action="/Cart/AddToCart" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="productId" value="@product.Id" />
                                        <input type="hidden" name="quantity" value="1" />
                                        <button type="submit" class="btn btn-primary-brand w-100 btn-sm">
                                            <i class="bi bi-bag-plus me-1"></i>Add to Cart
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <button class="btn btn-sm w-100" disabled style="background:var(--brand-light); color:var(--brand-muted); border:1.5px solid var(--brand-border);">
                                        Out of Stock
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
